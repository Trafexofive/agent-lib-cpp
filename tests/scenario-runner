#!/usr/bin/env bash
# scenario-runner — run MK3 protocol compliance scenarios against live LLM
# Usage: ./tests/scenario-runner [--model deepseek-v4-pro] [--provider deepseek]
#
# Each run gets its own temp dir → no state leakage between runs.
# Captures: iterations.md, raw.md, stdout, stderr, filtered output.
set -euo pipefail

MODEL="${CORTEX_MODEL:-deepseek-v4-pro}"
PROVIDER="${CORTEX_PROVIDER:-deepseek}"
N_RUNS="${N_RUNS:-3}"          # runs per scenario
TIMEOUT="${TIMEOUT:-60}"        # seconds per run
MK3_BIN="${MK3_BIN:-./cortex-mk3}"
RESULTS_DIR="${RESULTS_DIR:-/tmp/mk3-scenarios}"
FILTER="${FILTER:-tests/context-filter}"

mkdir -p "$RESULTS_DIR"

# ── Scenarios ───────────────────────────────────────────────────────────
# Format: ID|prompt
# Tests: simple answer, parallel cold start, data piping, error recovery, full pipeline
SCENARIOS=(
"simple|What is 2+2?"
"parallel|What is the state of this project? Check git status, list the files in the current directory, and count how many .cpp source files exist — all at once."
"pipe|Find all TODO comments in the src/ directory and count them by file using the grep output."
"recover|Read a file called nonexistent.json and handle the error properly."
"pipeline|Analyze my system: check CPU model, available memory, and disk usage. Save a summary report."
)

# ── Run all scenarios ───────────────────────────────────────────────────
for scenario in "${SCENARIOS[@]}"; do
    id="${scenario%%|*}"
    prompt="${scenario#*|}"
    
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  SCENARIO: $id  |  N=$N_RUNS  |  model=$MODEL"
    echo "  prompt: $prompt"
    echo "═══════════════════════════════════════════════════════════════"
    
    for run in $(seq 1 $N_RUNS); do
        rundir="$RESULTS_DIR/${id}_run${run}"
        rm -rf "$rundir"
        mkdir -p "$rundir"
        
        # Run in an isolated temp dir to avoid state leakage
        (
            cd "$(dirname "$MK3_BIN")" || exit 1
            bin="$(basename "$MK3_BIN")"
            
            timeout "$TIMEOUT" "./$bin" \
                --provider "$PROVIDER" \
                --model "$MODEL" \
                --raw run \
                -p "$prompt" \
                > "$rundir/stdout.txt" 2>"$rundir/stderr.txt"
            
            # Capture the protocol dumps generated by the binary
            cp raw.md "$rundir/raw.md" 2>/dev/null || true
            cp iterations.md "$rundir/iterations.md" 2>/dev/null || true
        )
        
        # Analyze with context-filter
        if [ -f "$rundir/iterations.md" ]; then
            "$FILTER" --stats "$rundir/iterations.md" > "$rundir/stats.txt" 2>&1
            "$FILTER" --only-agent "$rundir/iterations.md" > "$rundir/agent-turns.txt" 2>&1
        fi
        
        # Quick summary
        first_line=$(head -1 "$rundir/stdout.txt" 2>/dev/null || echo "(empty)")
        iter_size=$(wc -c < "$rundir/iterations.md" 2>/dev/null || echo 0)
        raw_size=$(wc -c < "$rundir/raw.md" 2>/dev/null || echo 0)
        printf "  run %d: first=[%s] iter=%d raw=%d\n" "$run" "${first_line:0:80}" "$iter_size" "$raw_size"
    done
done

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  RESULTS: $RESULTS_DIR"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "To inspect a run:"
echo "  tests/context-filter $RESULTS_DIR/<scenario>_run1/iterations.md --only-agent"
echo "  cat $RESULTS_DIR/<scenario>_run1/stdout.txt"
